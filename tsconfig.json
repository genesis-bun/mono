{
	"compilerOptions": {
		"jsx": "react-jsx",
		"allowJs": true,
		"strictNullChecks": true,
		"strict": true,
		// Bundler mode
		"moduleResolution": "bundler",
		"module": "Preserve",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@assets/*": ["./src/assets/*"]
		},
		"target": "ESNext",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["**/*.ts", "**/*.tsx", "a.js"],
	"exclude": ["dist", "node_modules"]
}
